#!/usr/bin/env bash
# polyglot -*- mode: sh -*-
# Main script for polyglot projects, to hook into cargo.
# polyglot is aliased as 'pg_' in places
#set -o errexit
set -o nounset
set -o pipefail

POLYGLOT_VERSION="0.2.0"

current_script_path=$(realpath "${BASH_SOURCE[0]}")
POLY_SRC=$(realpath "$(dirname "$current_script_path")")

PATH="$POLY_SRC/cmds:$PATH"
# shellcheck disable=SC1091
source "$POLY_SRC/lib/lib-util.bash"

function maybe-run-new () {
    if [[ "${1:-}" = "new" ]]; then
        shift
        # early override for when you aren't in a workspace,
        # and want one.
        # shellcheck disable=SC2097,SC2098
        POLY_SRC="$POLY_SRC" polyglot-new "$@"
        exit "$?"
    fi
}

function print-help () {
    # test args, if the last one is -h or --help
    # print help and exit
    case "${@: -1}" in
        -h|--help) ;;
        *) [[ "$#" = 0 ]] || return ;;
    esac
    # shellcheck disable=SC2098,SC2097
    POLY_SRC="$POLY_SRC" polyglot-help
    exit 0
}

function print-version () {
    case "${@: -1}" in
        -v|--version) echo "$POLYGLOT_VERSION" && exit 0 ;;
    esac
}

# General
VERBOSE=${VERBOSE:-0}

case "${POLYGLOT_ROOT:-}" in
    "") # Not in a workspace
        print-help "$@"
        print-version "$@"
        maybe-run-new "$@"
        fail "(Polyglot $POLYGLOT_VERSION): Make sure theres a POLYGLOT_ROOT env var, or run 'polyglot new'"
    ;;
    *) # In a workspace
        print-version "$@"
        cmd="polyglot-${1:-help}"
        shift
        POLY_SRC="$POLY_SRC" "$cmd" "$@"
        exit "$?"
    ;;
esac
