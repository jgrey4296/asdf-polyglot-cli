#!/usr/bin/env bash
# polyglot-list.bash -*- mode: sh -*-
#set -o errexit
set -o nounset
set -o pipefail

source "$POLY_SRC/lib/lib-util.bash"

PRINTED_HELP="${PRINTED_HELP:-2}"
HELP_TEXT="
usage: polyglot list [-h] [arg]

List available tasks, languages, and tools.

positional arguments:
arg          : t|tasks l|langs o|tools

options:
-h, --help    : show this help message and exit

"

function print-help () {
    case "${@: 1}" in
        -h|--help) ;;
        *) if [[ "$#" -gt 0 ]]; then
               return
           fi
           ;;
    esac
    echo -e "$HELP_TEXT"
    exit "$PRINTED_HELP"
}

print-help "$@"
TARGET=""
case "${1:-}" in
    tasks|t)
        TARGET="task-"
        ;;
    langs|l)
        TARGET="lang-"
        ;;
    tools|o)
        TARGET="tool-"
        ;;
    templates)
        fail "TODO"
        ;;
    *)
        echo "Unknown target"
        exit 1
        ;;
esac

echo -e "Polyglot Registered ${TARGET/-/}s:"
base=$(realpath "$POLYGLOT_ROOT/.tasks")
for targ in $(find "$base" -maxdepth 1 -name "${TARGET}*" | sort -V)
do
    name=$(basename "$targ")
    echo "- ${name/$TARGET/}"
done
